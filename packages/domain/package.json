{
  "name": "@sad-rbpl/domain",
  "version": "1.0.0",
  "private": true,
  "description": "Domain logic for SAD diesel machine booking platform",
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "exports": {
    "./*": "./dist/src/*.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "clean": "rimraf dist",
    "build": "tsc -b",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts,.tsx",
    "format": "prettier --write \"src/**/*.{ts,tsx}\""
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "eslint": "^9",
    "prettier": "^3.2.5",
    "rimraf": "^6",
    "typescript": "^5.8.2"
  }
}
