{
  "name": "api",
  "version": "1.0.0",
  "description": "REST API handling authentication, business logic, and data persistence. REST API service for user, manager, and admin applications",
  "scripts": {
    "dev": "ts-node-dev -r tsconfig-paths/register --respawn --transpile-only src/index.ts",
    "build": "npx prisma generate && tsc && npx tsc-alias",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "prisma:seed": "ts-node -r tsconfig-paths/register prisma/seed.ts",
    "lint": "eslint ."
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.7.1",
  "dependencies": {
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "^7.6.0",
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "express": "^5.1.0",
    "mongoose": "^8.13.2",
    "pg": "^8.20.0",
    "@domain": "workspace:domain-logic",
    "shared": "workspace:*"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.1",
    "@types/node": "^22.14.0",
    "@types/pg": "^8.20.0",
    "prisma": "^7.6.0",
    "ts-node-dev": "^2.0.0",
    "tsc-alias": "^1.8.16",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3"
  }
}