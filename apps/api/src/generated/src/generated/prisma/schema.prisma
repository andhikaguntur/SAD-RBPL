// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Mesin {
  idMesin     String    @id // misal "MSN-501"
  namaMesin   String
  kapasitas   String    @default("")
  status      String
  lokasi      String    @default("")
  lastService DateTime?
  pelanggan   String?

  permintaan PermintaanMesin[]
}

model PermintaanSewa {
  idPermintaan  String @id @default(uuid())
  pelanggan     String @default("")
  lokasi        String
  durasi        Int    @default(1)
  status        String
  tanggalFormat String @default("")

  mesin      PermintaanMesin[]
  pembayaran Pembayaran[]
  pengiriman Pengiriman[]
}

model PermintaanMesin {
  idPermintaan String
  idMesin      String
  qty          Int    @default(1)
  harga        Int    @default(0)
  diskon       Int    @default(0)

  permintaan PermintaanSewa @relation(fields: [idPermintaan], references: [idPermintaan], onDelete: Cascade)
  mesin      Mesin          @relation(fields: [idMesin], references: [idMesin], onDelete: Cascade)

  @@id([idPermintaan, idMesin])
}

model Pembayaran {
  id           String @id @default(uuid())
  idPermintaan String
  total        Int
  tanggal      String
  status       String
  bukti        String @default("")

  permintaan PermintaanSewa @relation(fields: [idPermintaan], references: [idPermintaan], onDelete: Cascade)
}

model Pengiriman {
  id              String @id @default(uuid())
  idPermintaan    String
  tanggalKirim    String
  sopir           String
  status          String
  buktiSuratJalan String @default("")

  permintaan PermintaanSewa @relation(fields: [idPermintaan], references: [idPermintaan], onDelete: Cascade)
}

model AuditLog {
  idLog         String   @id @default(uuid())
  entitasTarget String
  idTarget      String
  aksi          String
  keterangan    String
  timestamp     DateTime @default(now())
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  phone     String
  password  String
  role      String   @default("user")
  createdAt DateTime @default(now())
}
